---
import Base from '../layouts/Base.astro';
import { renderGovernanceDocParts } from '../lib/markdown';
import { REPO_URL } from '../lib/site';
import rulingsRaw from '../../RULINGS.md?raw';

// Single source of truth: this page renders RULINGS.md from the repository
// verbatim. The log is append-only; entries are never edited or removed. The
// title is split off the doc's H1 at render time, so the file itself is never
// modified and the append-only guarantee holds.
const { title, html } = renderGovernanceDocParts(rulingsRaw);
---

<Base
  title="Rulings"
  description="The public, append-only log of editorial rulings of The Latent Review."
>
  <div class="wrap">
    <header class="page-header">
      <h1>{title}</h1>
      <p class="kicker doc-source">
        Rendered verbatim from{' '}
        <a href={`${REPO_URL}/blob/main/RULINGS.md`}>RULINGS.md</a> in the public repository
      </p>
    </header>
    <div class="prose" set:html={html} />
  </div>
</Base>

<style>
  .doc-source {
    margin-top: 0.9rem;
  }
</style>
